rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users — any authenticated user can read (for search)
    // Only owner can write their own profile
    match /users/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // Conversations — only participants can read/write
    match /conversations/{conversationId} {
      allow read, update: if request.auth != null
        && request.auth.uid in resource.data.participants;

      allow create: if request.auth != null
        && request.auth.uid in request.resource.data.participants;

      // Messages — any authenticated user can read/write messages
      // inside a conversation (conversation-level rule already guards access)
      match /messages/{messageId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null
          && request.resource.data.senderId == request.auth.uid;
      }
    }
  }
}
