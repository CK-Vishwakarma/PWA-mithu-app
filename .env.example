# ─── Firebase Configuration ───────────────────────────────────────
# Copy this file to .env.local and fill in your values
# Firebase Console → Project Settings → Your apps
# https://console.firebase.google.com

NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ─── AWS S3 Configuration ─────────────────────────────────────────
# Used for image and video uploads via presigned URLs
# AWS Console → IAM → Users → Your user → Security credentials
# https://console.aws.amazon.com/iam

# IAM user access key (server-side only — never expose to client)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# S3 bucket details
# AWS Console → S3 → Your bucket
AWS_REGION=us-east-1
AWS_S3_BUCKET_NAME=

# Public base URL for accessing uploaded files
# Format: https://<bucket-name>.s3.<region>.amazonaws.com
AWS_S3_PUBLIC_URL=
